# Copy to .env (gitignored) and fill in. Never commit real values.

# --- Magento 2 store (dev: Warden) ---
MAGENTO_BASE_URL=https://app.demo.test
# Admin > System > Integrations > create integration, then paste the access token:
MAGENTO_ACCESS_TOKEN=
# Skip TLS verify for local self-signed Warden certs (dev only):
MAGENTO_VERIFY_SSL=false

# --- LLM provider ---
# One of: claude | bedrock
CATALOGGUARD_LLM_PROVIDER=claude
ANTHROPIC_API_KEY=
# Default to the latest Claude model:
CATALOGGUARD_LLM_MODEL=claude-opus-4-8
# Bedrock (only if provider=bedrock):
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# --- Tracing / eval (optional) ---
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=catalogguard
